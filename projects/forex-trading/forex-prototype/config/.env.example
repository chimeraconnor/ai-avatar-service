# API Keys - Copy this to .env and fill in your keys

# IBKR API (Paper Trading)
# NOTE: No gateway required! Just TWS or IB Gateway running locally
IBKR_ACCOUNT_ID=your_ibkr_account_id_here
IBKR_HOST=127.0.0.1
IBKR_PORT=7497  # 7496 for TWS, 7497 for IB Gateway

# EODHD API (Real-time Forex Data)
EODHD_API_KEY=your_eodhd_api_key_here
EODHD_BASE_URL=https://eodhd.com/api

# Trading Configuration
DEFAULT_PAIRS=EUR_USD,GBP_USD,USD_JPY
DEFAULT_TIMEFRAME=S1  # S1=1 second, M1=1 minute, H1=1 hour

# OANDA (DISABLED - Country restriction)
# OANDA_API_KEY=your_oanda_api_key_here
# OANDA_ACCOUNT_ID=your_demo_account_id_here
# OANDA_PRACTICE_URL=https://api-fxpractice.oanda.com/v3

# PostgreSQL Database (Optional - for now we'll use CSV)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forex_trading
DB_USER=trader
DB_PASSWORD=your_password_here

# MetaApi (DISABLED - Using IBKR instead)
# META_API_KEY=your_metaapi_token_here
# META_ACCOUNT_ID=your_account_id_here
# META_API_URL=https://metaapi.app/api
